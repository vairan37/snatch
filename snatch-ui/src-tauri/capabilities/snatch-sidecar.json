{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "snatch-sidecar",
  "description": "Allows executing the snatch sidecar",
  "windows": [
    "main"
  ],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "sidecar": true,
          "name": "binaries/snatch"
        }
      ]
    }
  ]
}
