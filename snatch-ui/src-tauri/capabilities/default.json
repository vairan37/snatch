{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
  "core:default",
  "opener:default",
  "store:default",
  "dialog:default",
  {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "name": "git"
        },
        {
          "args": true,
          "name": "bash"
        },
        {
          "args": true,
          "name": "sh"
        },
        {
          "args": true,
          "name": "cmd.exe"
        }
      ]
    }
  ]
}